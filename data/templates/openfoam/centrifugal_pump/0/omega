FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform {{OMEGA_INIT}};

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform {{OMEGA_INIT}};
    }

    outlet
    {
        type            zeroGradient;
    }

    impeller
    {
        type            omegaWallFunction;
        value           uniform {{OMEGA_INIT}};
    }

    walls
    {
        type            omegaWallFunction;
        value           uniform {{OMEGA_INIT}};
    }
}
