FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform {{K_INIT}};

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform {{K_INIT}};
    }

    outlet
    {
        type            zeroGradient;
    }

    impeller
    {
        type            kqRWallFunction;
        value           uniform {{K_INIT}};
    }

    walls
    {
        type            kqRWallFunction;
        value           uniform {{K_INIT}};
    }
}
