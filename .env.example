# HPE — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores antes de fazer deploy.
#
# Regra de prefixo:
#   HPE_*  → lidos por pydantic-settings (hpe.core.config.Settings)
#   sem prefixo → lidos diretamente por Celery, orchestrator e training_log
#
# Para produção: NUNCA commite o .env real. Use segredos do sistema de CI/CD.

# ─── PostgreSQL — HPE ─────────────────────────────────────────────────────────
# pydantic-settings
HPE_DATABASE_URL=postgresql://postgres:TROQUE_A_SENHA@db:5432/db_pump_engine
# Celery result backend / training_log / bancada_seed
DATABASE_URL=postgresql://postgres:TROQUE_A_SENHA@db:5432/db_pump_engine

# PostgreSQL HIGRA SIGS (somente leitura — bancada de ensaios)
DATABASE_SIGS_URL=postgresql://postgres:TROQUE_A_SENHA@localhost:5432/higra_sigs

# ─── Redis ────────────────────────────────────────────────────────────────────
HPE_REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# ─── MinIO (Object Storage) ───────────────────────────────────────────────────
HPE_MINIO_ENDPOINT=minio:9000
HPE_MINIO_ACCESS_KEY=minioadmin
HPE_MINIO_SECRET_KEY=TROQUE_A_SENHA
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=TROQUE_A_SENHA
MINIO_BUCKET=hpe-geometry

# ─── API / Auth ───────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE_PARA_VALOR_ALEATORIO_EM_PRODUCAO
API_PORT=8000

# ─── Modelos ML ───────────────────────────────────────────────────────────────
HPE_SURROGATE_PATH=/app/models/surrogate_v1.pkl
HPE_DATASET_DIR=/app/dataset

# ─── MLflow ───────────────────────────────────────────────────────────────────
# Para usar o MLflow interno ao compose, aponte para o serviço mlflow:
# HPE_MLFLOW_TRACKING_URI=http://mlflow:5000
# Para produção, aponte para o servidor MLflow dedicado:
HPE_MLFLOW_TRACKING_URI=http://localhost:5000

# ─── CFD ─────────────────────────────────────────────────────────────────────
# Caminho do OpenFOAM no host / container
# HPE_OPENFOAM_PATH=/opt/openfoam10
HPE_MAX_CFD_CORES=8

# ─── Claude API (opcional — RAG assistant) ───────────────────────────────────
# Se não definido, o assistant usa apenas regras offline (Gülich KB).
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Modo debug ───────────────────────────────────────────────────────────────
# HPE_DEBUG=true   # ativa SQL echo + stack traces completas na API
